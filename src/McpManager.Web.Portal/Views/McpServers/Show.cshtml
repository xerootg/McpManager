@using McpManager.Core.Data.Models.Mcp
@using McpManager.Web.Portal.Extensions
@using McpManager.Web.Portal.Services
@inject TokenCounterService TokenCounter
@model McpServer

@functions {
    string FormatJson(string json) {
        try {
            var obj = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(json);
            return System.Text.Json.JsonSerializer.Serialize(obj, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        } catch {
            return json;
        }
    }
}

@section PageActions {
    <form asp-action="Sync" asp-route-id="@Model.Id">
        <button type="submit" class="btn btn-ghost gap-2">
            <icon name="arrow-path" size="5" />
            <span class="hidden sm:inline">Sync</span>
        </button>
    </form>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-ghost gap-2">
        <icon name="pencil-square" size="5" />
        <span class="hidden sm:inline">Edit</span>
    </a>
    <partial name="_HelpButton" />
    <a asp-action="Index" class="btn btn-ghost gap-2">
        <icon name="arrow-left" size="5" />
        <span class="hidden sm:inline">Back</span>
    </a>
}

<div class="grid grid-cols-12 gap-6">
    <!-- Server Details -->
    <div class="col-span-12 lg:col-span-7">
        <div class="card bg-base-100 border border-base-200 mb-4">
            <div class="card-body p-4">
                <h3 class="font-semibold text-sm">Server Details</h3>
                <div class="grid grid-cols-12 gap-3">
                    <div class="col-span-12 md:col-span-6">
                        <label class="text-xs text-base-content/60">Name</label>
                        <p class="font-medium">@Model.Name</p>
                    </div>
                    <div class="col-span-12 md:col-span-6">
                        <label class="text-xs text-base-content/60">Status</label>
                        <p>
                            @if (Model.IsActive) {
                                <span class="badge badge-success">Active</span>
                            } else {
                                <span class="badge badge-error">Inactive</span>
                            }
                        </p>
                    </div>
                    <div class="col-span-12 md:col-span-6">
                        <label class="text-xs text-base-content/60">Transport</label>
                        <p>
                            @switch (Model.TransportType) {
                                case McpTransportType.Http:
                                    <span class="badge badge-info badge-sm">HTTP</span>
                                    break;
                                case McpTransportType.Sse:
                                    <span class="badge badge-info badge-sm">SSE</span>
                                    break;
                                case McpTransportType.OpenApi:
                                    <span class="badge badge-secondary badge-sm">OpenAPI</span>
                                    break;
                                case McpTransportType.Stdio:
                                    <span class="badge badge-warning badge-sm">Stdio</span>
                                    break;
                                default:
                                    <span class="badge badge-ghost badge-sm">Unknown</span>
                                    break;
                            }
                        </p>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Description)) {
                        <div class="col-span-12">
                            <label class="text-xs text-base-content/60">Description</label>
                            <p>@Model.Description</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (Model.TransportType == McpTransportType.OpenApi) {
            <div class="card bg-base-100 border border-base-200 mb-4">
                <div class="card-body p-4">
                    <h3 class="font-semibold text-sm">REST API Connection</h3>
                    <div class="grid grid-cols-12 gap-3">
                        <div class="col-span-12">
                            <label class="text-xs text-base-content/60">Base URL</label>
                            <p class="font-mono text-sm break-all">@Model.Uri</p>
                        </div>
                        <div class="col-span-12 md:col-span-6">
                            <label class="text-xs text-base-content/60">Auth Type</label>
                            <p>@Model.Auth.Type</p>
                        </div>
                        <div class="col-span-12 md:col-span-6">
                            <label class="text-xs text-base-content/60">Specification</label>
                            <p class="text-sm">@(Model.OpenApiSpecification?.Length.ToString("N0") ?? "0") characters</p>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.CustomHeaders.Any()) {
                <div class="card bg-base-100 border border-base-200 mb-4">
                    <div class="card-body p-4">
                        <h3 class="font-semibold text-sm">Custom Headers</h3>
                        <div class="overflow-x-auto">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Header</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var header in Model.CustomHeaders) {
                                        <tr>
                                            <td class="font-mono text-sm">@header.Key</td>
                                            <td class="font-mono text-sm">@header.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        } else if (Model.TransportType == McpTransportType.Http) {
            <div class="card bg-base-100 border border-base-200 mb-4">
                <div class="card-body p-4">
                    <h3 class="font-semibold text-sm">Remote Connection</h3>
                    <div class="grid grid-cols-12 gap-3">
                        <div class="col-span-12">
                            <label class="text-xs text-base-content/60">URI</label>
                            <p class="font-mono text-sm break-all">@Model.Uri</p>
                        </div>
                        <div class="col-span-12">
                            <label class="text-xs text-base-content/60">Auth Type</label>
                            <p>@Model.Auth.Type</p>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.CustomHeaders.Any()) {
                <div class="card bg-base-100 border border-base-200 mb-4">
                    <div class="card-body p-4">
                        <h3 class="font-semibold text-sm">Custom Headers</h3>
                        <div class="overflow-x-auto">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Header</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var header in Model.CustomHeaders) {
                                        <tr>
                                            <td class="font-mono text-sm">@header.Key</td>
                                            <td class="font-mono text-sm">@header.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        } else {
            var simple = McpCommandBuilder.ParseSimplePackageCommand(Model.Command, Model.Arguments);
            <div class="card bg-base-100 border border-base-200 mb-4">
                <div class="card-body p-4">
                    <h3 class="font-semibold text-sm">Local Server</h3>
                    <div class="grid grid-cols-12 gap-3">
                        @if (simple != null) {
                            <div class="col-span-12 md:col-span-4">
                                <label class="text-xs text-base-content/60">Package Runner</label>
                                <p class="font-mono text-sm">@Model.Command</p>
                            </div>
                            <div class="col-span-12 md:col-span-8">
                                <label class="text-xs text-base-content/60">Package</label>
                                <p class="font-mono text-sm">@simple.Package</p>
                            </div>
                            @if (simple.ExtraArguments.Count > 0) {
                                <div class="col-span-12">
                                    <label class="text-xs text-base-content/60">Additional Arguments</label>
                                    <p class="font-mono text-sm">@string.Join(" ", simple.ExtraArguments)</p>
                                </div>
                            }
                        } else {
                            <div class="col-span-12">
                                <label class="text-xs text-base-content/60">Command</label>
                                <p class="font-mono text-sm">@Model.Command</p>
                            </div>
                            @if (Model.Arguments.Any()) {
                                <div class="col-span-12">
                                    <label class="text-xs text-base-content/60">Arguments</label>
                                    <p class="font-mono text-sm">@string.Join(" ", Model.Arguments)</p>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            @if (Model.EnvironmentVariables.Any()) {
                <div class="card bg-base-100 border border-base-200 mb-4">
                    <div class="card-body p-4">
                        <h3 class="font-semibold text-sm">Environment Variables</h3>
                        <div class="overflow-x-auto">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Key</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var envVar in Model.EnvironmentVariables) {
                                        <tr>
                                            <td class="font-mono text-sm">@envVar.Key</td>
                                            <td class="font-mono text-sm">@envVar.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Metadata -->
    <div class="col-span-12 lg:col-span-5">
        <div class="card bg-base-100 border border-base-200 mb-4">
            <div class="card-body p-4">
                <h3 class="font-semibold text-sm">Metadata</h3>
                <div class="flex flex-col gap-2">
                    <div>
                        <label class="text-xs text-base-content/60">Created</label>
                        <p class="text-sm">@Model.CreationTime.ToString("g")</p>
                    </div>
                    <div>
                        <label class="text-xs text-base-content/60">Last Sync</label>
                        <p class="text-sm">
                            @if (Model.LastSyncTime.HasValue) {
                                @Model.LastSyncTime.Value.ToString("g")
                            } else {
                                <span class="text-base-content/50">Never synced</span>
                            }
                        </p>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.LastError)) {
                        <div>
                            <label class="text-xs text-base-content/60">Last Error</label>
                            <p class="text-sm text-error">@Model.LastError</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Error Logs Section -->
@{
    var logs = (List<McpServerLog>)ViewData["RecentLogs"];
}
@if (logs.Any()) {
    <div class="card bg-base-100 border border-base-200 mb-6">
        <div class="card-body p-4">
            <h3 class="font-semibold text-sm mb-2">Recent Logs</h3>
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th class="w-1">Level</th>
                            <th>Message</th>
                            <th class="w-1">Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in logs) {
                            <tr>
                                <td>
                                    @switch (log.Level) {
                                        case McpServerLogLevel.Error:
                                            <span class="badge badge-error badge-sm">Error</span>
                                            break;
                                        case McpServerLogLevel.Warning:
                                            <span class="badge badge-warning badge-sm">Warning</span>
                                            break;
                                        default:
                                            <span class="badge badge-info badge-sm">Info</span>
                                            break;
                                    }
                                </td>
                                <td class="text-sm max-w-lg truncate">@log.Message</td>
                                <td class="text-sm text-base-content/60 whitespace-nowrap">@log.CreationTime.ToString("g")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section HelpSidebar {
    <div class="space-y-4 text-sm">
        <div>
            <h3 class="font-semibold text-sm mb-1">Server Details</h3>
            <p class="text-base-content/70">View the configuration and current state of this MCP server, including its connection details and authentication settings.</p>
        </div>
        <div>
            <h3 class="font-semibold text-sm mb-1">Tools</h3>
            <p class="text-base-content/70">The tools list shows all tools discovered from this server after syncing. Each tool includes its name, description, and input schema.</p>
        </div>
        <div>
            <h3 class="font-semibold text-sm mb-1">Actions</h3>
            <ul class="list-disc list-inside text-base-content/70 space-y-1">
                <li><strong>Sync</strong> &mdash; re-discover tools from the server</li>
                <li><strong>Edit</strong> &mdash; modify server configuration</li>
            </ul>
        </div>
        <div>
            <h3 class="font-semibold text-sm mb-1">Health &amp; Logs</h3>
            <p class="text-base-content/70">Recent logs show connection errors and warnings. Check <strong>Last Error</strong> in metadata if the server isn't responding.</p>
        </div>
    </div>
}

<!-- Tools Section -->
<div class="card bg-base-100 border border-base-200">
    <div class="card-body p-4">
        @{
            var totalTokens = Model.Tools.Sum(t => TokenCounter.CountToolTokens(t.CustomDescription ?? t.Description, t.CustomInputSchema ?? t.InputSchema));
        }
        <div class="flex items-center justify-between mb-2">
            <h3 class="font-semibold text-sm">Tools (@Model.Tools.Count)</h3>
            @if (Model.Tools.Any()) {
                <span class="badge badge-ghost badge-sm">@totalTokens.ToString("N0") tokens total</span>
            }
        </div>
        @if (Model.Tools.Any()) {
            <div class="flex flex-col gap-3">
                @foreach (var tool in Model.Tools.OrderBy(t => t.Name)) {
                    var effectiveDescription = tool.CustomDescription ?? tool.Description;
                    var effectiveSchema = tool.CustomInputSchema ?? tool.InputSchema;
                    var isCustomized = tool.CustomDescription != null || tool.CustomInputSchema != null;
                    var toolTokens = TokenCounter.CountToolTokens(effectiveDescription, effectiveSchema);
                    <div class="border border-base-200 rounded-lg p-3">
                        <div class="flex items-start justify-between gap-2 mb-2">
                            <div>
                                <h4 class="font-medium text-sm">
                                    @tool.Name
                                    @if (isCustomized) {
                                        <span class="badge badge-accent badge-xs ml-1">customized</span>
                                    }
                                </h4>
                                @if (!string.IsNullOrWhiteSpace(effectiveDescription)) {
                                    <p class="text-xs text-base-content/60">@effectiveDescription</p>
                                }
                            </div>
                            <div class="flex items-center gap-1">
                                <span class="badge badge-ghost badge-xs">@toolTokens tokens</span>
                                @if (tool.TotalRequests > 0) {
                                    <span class="badge badge-ghost badge-sm">@tool.TotalRequests requests</span>
                                }
                                @if (Model.TransportType == McpTransportType.OpenApi) {
                                    <a class="show-ajax-form-modal btn btn-ghost btn-sm btn-square"
                                       data-url="@Url.Action("EditTool", new { id = Model.Id, toolId = tool.Id })"
                                       data-title="Edit Tool">
                                        <icon name="pencil-square" size="4" />
                                    </a>
                                }
                            </div>
                        </div>
                        @if (effectiveSchema != "{}") {
                            <div class="mt-2">
                                <label class="text-xs text-base-content/60">Input Schema</label>
                                <pre class="bg-base-200 rounded p-2 text-xs overflow-x-auto mt-1"><code>@FormatJson(effectiveSchema)</code></pre>
                            </div>
                        }
                    </div>
                }
            </div>
        } else {
            <partial name="_NoRecords" model="@("No tools synced yet")" />
        }
    </div>
</div>
